# Variables de entorno para VozCiudadana Backend
# Copiar este archivo a .env y completar con valores reales

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voz:secret@localhost:5432/vozcuidadana

# ── Redis (FSM de estados del bot) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── WhatsApp / Meta ───────────────────────────────────────────────────────────
# Token de verificación del webhook (lo define el administrador)
WHATSAPP_VERIFY_TOKEN=my_verify_token_here
# App Secret de la app Meta (para validar X-Hub-Signature-256)
WHATSAPP_APP_SECRET=my_app_secret_here
# Token de acceso de la API Cloud de WhatsApp
WHATSAPP_ACCESS_TOKEN=my_access_token_here
# ID del número de teléfono registrado en Meta
WHATSAPP_PHONE_NUMBER_ID=123456789

# ── Seguridad general ─────────────────────────────────────────────────────────
SECRET_KEY=cambia_esto_en_produccion

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia_esto_en_produccion_jwt
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Entorno de ejecución ──────────────────────────────────────────────────────
ENVIRONMENT=development
