// Variables de entorno requeridas para el backend NestJS
// Copiá este archivo a .env y completá los valores

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://voz:secret@localhost:5432/vozcuidadana"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── WhatsApp Meta API ──────────────────────────────────────────────────────────
# Token de verificación configurado en el panel Meta for Developers
WA_VERIFY_TOKEN=your_verify_token_here
# App Secret de la app Meta (para validar firma HMAC)
WA_APP_SECRET=your_app_secret_here
# Token de acceso permanente para enviar mensajes
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
# ID del número de teléfono de WhatsApp Business
WA_PHONE_NUMBER_ID=your_phone_number_id_here

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
