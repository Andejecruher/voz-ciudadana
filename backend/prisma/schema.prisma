generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceChannel {
  whatsapp
  web
  event
  referral
  other

  @@map("source_channel")
}

enum LeadStatus {
  new
  contacted
  engaged
  converted
  unsubscribed

  @@map("lead_status")
}

enum ConversationStatus {
  open
  in_progress
  resolved
  closed

  @@map("conversation_status")
}

enum ConversationChannel {
  whatsapp
  web_chat
  email
  sms
  other

  @@map("conversation_channel")
}

enum MessageDirection {
  inbound
  outbound

  @@map("message_direction")
}

enum MessageType {
  text
  image
  audio
  video
  document
  location
  template
  interactive
  system

  @@map("message_type")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique @db.VarChar(255)
  hashedPassword String   @map("hashed_password") @db.VarChar(255)
  fullName       String?  @map("full_name") @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  isSuperuser    Boolean  @default(false) @map("is_superuser")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles UserRole[]

  assignedConversations Conversation[] @relation("ConversationAssignedUser")
  assignedCitizenTags   CitizenTag[]   @relation("CitizenTagAssignedBy")
  uploadedAttachments   Attachment[]   @relation("AttachmentUploadedBy")

  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles UserRole[]

  @@index([name])
  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uq_user_roles_user_role")
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Neighborhood {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(255)
  nameLower   String   @map("name_lower") @db.VarChar(255)
  description String?  @db.Text
  zone        String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  citizens Citizen[]

  @@index([name])
  @@index([nameLower])
  @@index([zone])
  @@map("neighborhoods")
}

model Citizen {
  id             String        @id @default(uuid()) @db.Uuid
  phone          String        @unique @db.VarChar(30)
  name           String?       @db.VarChar(255)
  lastName       String?       @map("last_name") @db.VarChar(255)
  email          String?       @db.VarChar(255)
  sourceChannel  SourceChannel @default(whatsapp) @map("source_channel")
  leadStatus     LeadStatus    @default(new) @map("lead_status")
  consentGiven   Boolean       @default(false) @map("consent_given")
  consentAt      DateTime?     @map("consent_at") @db.Timestamptz(6)
  neighborhood   String?       @db.VarChar(255)
  neighborhoodId String?       @map("neighborhood_id") @db.Uuid
  interests      String[]      @default([]) @db.Text
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  neighborhoodRef Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)

  conversations Conversation[]
  citizenTags   CitizenTag[]
  attachments   Attachment[]

  @@index([phone])
  @@index([email])
  @@map("citizens")
}

model Conversation {
  id             String              @id @default(uuid()) @db.Uuid
  citizenId      String              @map("citizen_id") @db.Uuid
  status         ConversationStatus  @default(open)
  channel        ConversationChannel @default(whatsapp)
  assignedDept   String?             @map("assigned_dept") @db.VarChar(100)
  assignedUserId String?             @map("assigned_user_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  citizen Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  assignedUser User? @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages Message[]

  @@index([assignedUserId])
  @@map("conversations")
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  conversationId    String           @map("conversation_id") @db.Uuid
  body              String           @db.Text
  direction         MessageDirection
  messageType       MessageType      @default(text) @map("message_type")
  externalMessageId String?          @map("external_message_id") @db.VarChar(255)
  attachmentId      String?          @map("attachment_id") @db.Uuid
  meta              Json             @default("{}") @db.JsonB
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  attachment Attachment? @relation("MessageAttachmentByAttachmentId", fields: [attachmentId], references: [id], onDelete: SetNull)

  attachmentsViaMessageId Attachment[] @relation("AttachmentBelongsToMessage")

  @@index([externalMessageId])
  @@map("messages")
}

model Attachment {
  id               String   @id @default(uuid()) @db.Uuid
  storageKey       String   @map("storage_key") @db.VarChar(1024)
  mimeType         String   @map("mime_type") @db.VarChar(127)
  fileSizeBytes    BigInt   @map("file_size_bytes")
  originalFilename String?  @map("original_filename") @db.VarChar(512)
  cdnUrl           String?  @map("cdn_url") @db.Text
  messageId        String?  @map("message_id") @db.Uuid
  citizenId        String?  @map("citizen_id") @db.Uuid
  uploadedBy       String?  @map("uploaded_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  message Message? @relation("AttachmentBelongsToMessage", fields: [messageId], references: [id], onDelete: SetNull)

  citizen   Citizen? @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  uploader  User?    @relation("AttachmentUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  messagesViaAttachmentId Message[] @relation("MessageAttachmentByAttachmentId")

  @@index([messageId])
  @@index([citizenId])
  @@map("attachments")
}

model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  citizenTags CitizenTag[]

  @@index([name])
  @@map("tags")
}

model CitizenTag {
  id           String   @id @default(uuid()) @db.Uuid
  citizenId    String   @map("citizen_id") @db.Uuid
  tagId        String   @map("tag_id") @db.Uuid
  assignedById String?  @map("assigned_by_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  citizen Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  assignedBy User? @relation("CitizenTagAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([citizenId, tagId], map: "uq_citizen_tags_citizen_tag")
  @@index([citizenId])
  @@index([tagId])
  @@map("citizen_tags")
}
