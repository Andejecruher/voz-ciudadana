generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceChannel {
  whatsapp
  web
  event
  referral
  other

  @@map("source_channel")
}

enum LeadStatus {
  new
  contacted
  engaged
  converted
  unsubscribed

  @@map("lead_status")
}

enum ConversationStatus {
  open
  in_progress
  resolved
  closed

  @@map("conversation_status")
}

enum ConversationChannel {
  whatsapp
  web_chat
  email
  sms
  other

  @@map("conversation_channel")
}

enum MessageDirection {
  inbound
  outbound

  @@map("message_direction")
}

enum MessageType {
  text
  image
  audio
  video
  document
  location
  template
  interactive
  system

  @@map("message_type")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique @db.VarChar(255)
  hashedPassword String   @map("hashed_password") @db.VarChar(255)
  fullName       String?  @map("full_name") @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  isSuperuser    Boolean  @default(false) @map("is_superuser")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles UserRole[]

  auditLogs AuditLog[] @relation("AuditLogActor")

  assignedConversations Conversation[] @relation("ConversationAssignedUser")
  assignedCitizenTags   CitizenTag[]   @relation("CitizenTagAssignedBy")
  uploadedAttachments   Attachment[]   @relation("AttachmentUploadedBy")
  assignments           Assignment[]   @relation("AssignmentUser")
  organizedEvents       Event[]        @relation("EventOrganizer")
  eventCheckins         EventCheckin[] @relation("EventCheckinByUser")

  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles UserRole[]

  @@index([name])
  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uq_user_roles_user_role")
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Neighborhood {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(255)
  nameLower   String   @map("name_lower") @db.VarChar(255)
  description String?  @db.Text
  zone        String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  citizens Citizen[]

  @@index([name])
  @@index([nameLower])
  @@index([zone])
  @@map("neighborhoods")
}

model Citizen {
  id             String        @id @default(uuid()) @db.Uuid
  phone          String        @unique @db.VarChar(30)
  name           String?       @db.VarChar(255)
  lastName       String?       @map("last_name") @db.VarChar(255)
  email          String?       @db.VarChar(255)
  sourceChannel  SourceChannel @default(whatsapp) @map("source_channel")
  leadStatus     LeadStatus    @default(new) @map("lead_status")
  consentGiven   Boolean       @default(false) @map("consent_given")
  consentAt      DateTime?     @map("consent_at") @db.Timestamptz(6)
  neighborhood   String?       @db.VarChar(255)
  neighborhoodId String?       @map("neighborhood_id") @db.Uuid
  interests      String[]      @default([]) @db.Text
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  neighborhoodRef Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)

  conversations      Conversation[]
  citizenTags        CitizenTag[]
  attachments        Attachment[]
  eventRegistrations EventRegistration[]

  @@index([phone])
  @@index([email])
  @@map("citizens")
}

model Conversation {
  id             String              @id @default(uuid()) @db.Uuid
  citizenId      String              @map("citizen_id") @db.Uuid
  status         ConversationStatus  @default(open)
  channel        ConversationChannel @default(whatsapp)
  assignedDept   String?             @map("assigned_dept") @db.VarChar(100)
  assignedUserId String?             @map("assigned_user_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  citizen Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  assignedUser User? @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages    Message[]
  assignments Assignment[]
  meta        ConversationMeta?

  @@index([assignedUserId])
  @@index([citizenId, status])
  @@map("conversations")
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  conversationId    String           @map("conversation_id") @db.Uuid
  body              String           @db.Text
  direction         MessageDirection
  messageType       MessageType      @default(text) @map("message_type")
  externalMessageId String?          @map("external_message_id") @db.VarChar(255)
  attachmentId      String?          @map("attachment_id") @db.Uuid
  meta              Json             @default("{}") @db.JsonB
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  attachment Attachment? @relation("MessageAttachmentByAttachmentId", fields: [attachmentId], references: [id], onDelete: SetNull)

  attachmentsViaMessageId Attachment[] @relation("AttachmentBelongsToMessage")
  statuses                MessageStatus[]

  @@index([externalMessageId])
  @@map("messages")
}

model Attachment {
  id               String   @id @default(uuid()) @db.Uuid
  storageKey       String   @map("storage_key") @db.VarChar(1024)
  mimeType         String   @map("mime_type") @db.VarChar(127)
  fileSizeBytes    BigInt   @map("file_size_bytes")
  originalFilename String?  @map("original_filename") @db.VarChar(512)
  cdnUrl           String?  @map("cdn_url") @db.Text
  messageId        String?  @map("message_id") @db.Uuid
  citizenId        String?  @map("citizen_id") @db.Uuid
  uploadedBy       String?  @map("uploaded_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  message Message? @relation("AttachmentBelongsToMessage", fields: [messageId], references: [id], onDelete: SetNull)

  citizen   Citizen? @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  uploader  User?    @relation("AttachmentUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  messagesViaAttachmentId Message[] @relation("MessageAttachmentByAttachmentId")

  @@index([messageId])
  @@index([citizenId])
  @@map("attachments")
}

model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  citizenTags CitizenTag[]

  @@index([name])
  @@map("tags")
}

// ── Auditoría de acciones administrativas ─────────────────────────────────────

/// Registro inmutable de acciones sensibles realizadas por usuarios admin.
/// No se eliminan ni modifican — append-only por diseño.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid    // null si la acción fue del sistema
  action     String   @db.VarChar(100)              // ej: "user.create", "user.deactivate"
  targetType String   @map("target_type") @db.VarChar(50)  // ej: "User", "Role"
  targetId   String?  @map("target_id") @db.VarChar(255)
  metadata   Json     @default("{}") @db.JsonB      // datos adicionales de la acción
  ip         String?  @db.VarChar(45)               // IPv4 o IPv6
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model CitizenTag {
  id           String   @id @default(uuid()) @db.Uuid
  citizenId    String   @map("citizen_id") @db.Uuid
  tagId        String   @map("tag_id") @db.Uuid
  assignedById String?  @map("assigned_by_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  citizen Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  assignedBy User? @relation("CitizenTagAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([citizenId, tagId], map: "uq_citizen_tags_citizen_tag")
  @@index([citizenId])
  @@index([tagId])
  @@map("citizen_tags")
}

// ── Messaging Core ────────────────────────────────────────────────────────────

enum ConversationFlowState {
  BOT_FLOW
  REGISTERING
  DEPARTMENT_ROUTING
  HUMAN_FLOW
  ESCALATED
  CLOSED

  @@map("conversation_flow_state")
}

enum MessageStatusValue {
  sent
  delivered
  read
  failed

  @@map("message_status_value")
}

enum InboxEventStatus {
  pending
  processing
  processed
  failed
  dead_lettered

  @@map("inbox_event_status")
}

enum OutboxEventStatus {
  pending
  sending
  sent
  failed
  dead_lettered

  @@map("outbox_event_status")
}

/// Extiende Conversation con estado de la máquina de estados de orquestación.
/// Se agrega como modelo separado para no romper el modelo Conversation existente.
model ConversationMeta {
  id             String                @id @default(uuid()) @db.Uuid
  conversationId String                @unique @map("conversation_id") @db.Uuid
  flowState      ConversationFlowState @default(BOT_FLOW) @map("flow_state")
  lockedByUserId String?               @map("locked_by_user_id") @db.Uuid
  lockedAt       DateTime?             @map("locked_at") @db.Timestamptz(6)
  version        Int                   @default(0)                             // optimistic locking
  departmentSlug String?               @map("department_slug") @db.VarChar(100)
  handoverAt     DateTime?             @map("handover_at") @db.Timestamptz(6)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([flowState])
  @@index([lockedByUserId])
  @@map("conversation_meta")
}

/// Registro de estado de entrega de mensajes outbound.
model MessageStatus {
  id         String             @id @default(uuid()) @db.Uuid
  messageId  String             @map("message_id") @db.Uuid
  wamid      String             @map("wamid") @db.VarChar(255)
  status     MessageStatusValue
  errorCode  Int?               @map("error_code")
  errorTitle String?            @map("error_title") @db.VarChar(255)
  timestamp  DateTime
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([wamid])
  @@index([messageId])
  @@map("message_statuses")
}

/// Eventos entrantes del webhook de Meta — inbox queue persistente.
model InboxEvent {
  id             String           @id @default(uuid()) @db.Uuid
  wamid          String           @unique @map("wamid") @db.VarChar(255)      // dedupe key
  phone          String           @db.VarChar(30)
  payload        Json             @db.JsonB
  status         InboxEventStatus @default(pending)
  retryCount     Int              @default(0) @map("retry_count")
  lastErrorAt    DateTime?        @map("last_error_at") @db.Timestamptz(6)
  lastError      String?          @map("last_error") @db.Text
  idempotencyKey String?          @map("idempotency_key") @db.VarChar(255)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt    DateTime?        @map("processed_at") @db.Timestamptz(6)

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("inbox_events")
}

/// Cola de eventos salientes — outbox pattern para garantizar entrega a Meta API.
model OutboxEvent {
  id             String            @id @default(uuid()) @db.Uuid
  conversationId String?           @map("conversation_id") @db.Uuid
  phone          String            @db.VarChar(30)
  payload        Json              @db.JsonB
  status         OutboxEventStatus @default(pending)
  retryCount     Int               @default(0) @map("retry_count")
  nextRetryAt    DateTime?         @map("next_retry_at") @db.Timestamptz(6)
  lastError      String?           @map("last_error") @db.Text
  wamid          String?           @map("wamid") @db.VarChar(255)             // id retornado por Meta
  idempotencyKey String            @unique @map("idempotency_key") @db.VarChar(255)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  sentAt         DateTime?         @map("sent_at") @db.Timestamptz(6)

  @@index([phone])
  @@index([status, nextRetryAt])
  @@index([conversationId])
  @@map("outbox_events")
}

/// Log de todos los webhooks recibidos de Meta (para auditoría y replay).
model WebhookEventLog {
  id             String   @id @default(uuid()) @db.Uuid
  correlationId  String   @map("correlation_id") @db.VarChar(255)
  rawPayload     Json     @map("raw_payload") @db.JsonB
  signature      String?  @db.VarChar(255)
  processedOk    Boolean  @default(false) @map("processed_ok")
  errorMessage   String?  @map("error_message") @db.Text
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([correlationId])
  @@index([createdAt])
  @@map("webhook_event_logs")
}

/// Departamentos disponibles para enrutamiento de conversaciones.
model Department {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  keywords    String[] @default([]) @db.Text                                  // para routing automático
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([slug])
  @@index([isActive])
  @@map("departments")
}

// ── Eventos ciudadanos ────────────────────────────────────────────────────────

enum EventStatus {
  draft
  published
  completed
  cancelled

  @@map("event_status")
}

enum EventType {
  townhall
  community
  volunteer
  campaign
  rally

  @@map("event_type")
}

enum RegistrationStatus {
  invited
  registered
  confirmed
  cancelled
  waitlist

  @@map("registration_status")
}

enum AttendanceStatus {
  pending
  attended
  no_show

  @@map("attendance_status")
}

/// Evento ciudadano organizado por el panel administrativo.
model Event {
  id              String      @id @default(uuid()) @db.Uuid
  title           String      @db.VarChar(255)
  slug            String      @unique @db.VarChar(255)
  description     String?     @db.Text
  eventType       EventType   @default(townhall) @map("event_type")
  status          EventStatus @default(draft)
  startsAt        DateTime    @map("starts_at") @db.Timestamptz(6)
  endsAt          DateTime?   @map("ends_at") @db.Timestamptz(6)
  locationName    String?     @map("location_name") @db.VarChar(255)
  address         String?     @db.VarChar(500)
  latitude        Decimal?    @db.Decimal(10, 7)
  longitude       Decimal?    @db.Decimal(10, 7)
  capacity        Int?
  organizerUserId String?     @map("organizer_user_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  organizer     User?               @relation("EventOrganizer", fields: [organizerUserId], references: [id], onDelete: SetNull)
  registrations EventRegistration[]
  checkins      EventCheckin[]

  @@index([status])
  @@index([startsAt])
  @@index([organizerUserId])
  @@map("events")
}

/// Registro de un ciudadano a un evento (RSVP + asistencia).
/// Un ciudadano solo puede tener un registro por evento.
model EventRegistration {
  id                 String             @id @default(uuid()) @db.Uuid
  eventId            String             @map("event_id") @db.Uuid
  citizenId          String             @map("citizen_id") @db.Uuid
  registrationStatus RegistrationStatus @default(registered) @map("registration_status")
  attendanceStatus   AttendanceStatus   @default(pending) @map("attendance_status")
  checkedInAt        DateTime?          @map("checked_in_at") @db.Timestamptz(6)
  sourceChannel      SourceChannel      @default(web) @map("source_channel")
  notes              String?            @db.Text
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  citizen  Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  checkins EventCheckin[]

  @@unique([eventId, citizenId], map: "uq_event_registrations_event_citizen")
  @@index([eventId])
  @@index([citizenId])
  @@index([registrationStatus])
  @@map("event_registrations")
}

/// Trazabilidad de check-ins para un registro de evento.
/// Permite múltiples check-ins por registro (reintentos/correcciones de staff).
model EventCheckin {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  registrationId String   @map("registration_id") @db.Uuid
  checkedInBy    String?  @map("checked_in_by") @db.Uuid
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  checkedInByUser User?          @relation("EventCheckinByUser", fields: [checkedInBy], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([registrationId])
  @@map("event_checkins")
}

/// Asignaciones de conversaciones a agentes humanos.
model Assignment {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  departmentSlug String?  @map("department_slug") @db.VarChar(100)
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  releasedAt     DateTime? @map("released_at") @db.Timestamptz(6)
  isActive       Boolean  @default(true) @map("is_active")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("AssignmentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([userId])
  @@index([isActive])
  @@map("assignments")
}
