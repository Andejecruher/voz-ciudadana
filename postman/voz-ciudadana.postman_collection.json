          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Healthcheck público. No requiere autenticación. Responde `{ status: 'ok', ts: ISO_DATE }`."
          }
        }
      ]
    },
    {
      "name": "02 · Auth",
      "description": "Endpoints de autenticación del panel administrativo.\nBase: `/api/v1/auth`\n\n**Rate limits activos:**\n- `/auth/login`: 10 req / 15 min por IP + lockout progresivo por email (60s→300s→900s→3600s)\n- `/auth/refresh`: 60 req / 5 min por IP",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 — login exitoso', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('accessToken presente', () => pm.expect(json).to.have.property('accessToken'));",
                  "pm.test('refreshToken presente', () => pm.expect(json).to.have.property('refreshToken'));",
                  "pm.test('user presente', () => pm.expect(json).to.have.property('user'));",
                  "pm.test('user.email es string', () => pm.expect(json.user?.email).to.be.a('string'));",
                  "pm.test('user.roles es array no vacío', () => pm.expect(json.user?.roles).to.be.an('array').with.length.above(0));",
                  "",
                  "if (json.accessToken)  pm.environment.set('access_token',  json.accessToken);",
                  "if (json.refreshToken) pm.environment.set('refresh_token', json.refreshToken);",
                  "if (json.user?.id)     pm.environment.set('user_id',       json.user.id);",
                  "",
                  "console.log('[Login] Sesión iniciada:', json.user?.email, '| Roles:', json.user?.roles?.join(', '));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "x-device-id",
                "value": "{{device_id}}",
                "description": "Identificador del dispositivo para multi-sesión (máx. 5 sesiones/usuario)"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superadmin_email}}\",\n  \"password\": \"{{superadmin_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Autentica un usuario del panel admin.\n\nExtrae automáticamente `access_token`, `refresh_token` y `user_id` como variables de entorno."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 — refresh exitoso', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('accessToken rotado', () => pm.expect(json).to.have.property('accessToken'));",
                  "pm.test('refreshToken rotado', () => pm.expect(json).to.have.property('refreshToken'));",
                  "",
                  "if (json.accessToken)  pm.environment.set('access_token',  json.accessToken);",
                  "if (json.refreshToken) pm.environment.set('refresh_token', json.refreshToken);",
                  "",
                  "console.log('[Refresh] Tokens rotados correctamente');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-device-id", "value": "{{device_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\",\n  \"deviceId\": \"{{device_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Rota el par access/refresh token. El token anterior es invalidado (single-use).\n\n**Rate limit:** 60 req / 5 min por IP."
          }
        },
