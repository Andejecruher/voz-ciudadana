    {
      "name": "04 · Webhook — WhatsApp",
      "description": "Endpoints del webhook de WhatsApp Cloud API.\nBase: `/api/v1/webhook`\n\n⚠️ Estos endpoints son invocados por Meta/WhatsApp, no por el panel admin directamente.",
      "item": [
        {
          "name": "Verificar webhook (Meta challenge)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Responde con el challenge en texto plano', () => {",
                  "  pm.expect(pm.response.text()).to.equal('CHALLENGE_STRING');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/webhook?hub.mode=subscribe&hub.verify_token={{webhook_verify_token}}&hub.challenge=CHALLENGE_STRING",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "webhook"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                {
                  "key": "hub.verify_token",
                  "value": "{{webhook_verify_token}}",
                  "description": "Debe coincidir con WHATSAPP_VERIFY_TOKEN en el servidor"
                },
                {
                  "key": "hub.challenge",
                  "value": "CHALLENGE_STRING",
                  "description": "Meta envía este valor; el server lo responde como texto plano con HTTP 200"
                }
              ]
            },
            "description": "Meta llama a este endpoint al configurar/reconfigurar el webhook.\n\n- `hub.mode` debe ser `subscribe`\n- `hub.verify_token` debe coincidir con `WHATSAPP_VERIFY_TOKEN` del servidor\n- El servidor responde con `hub.challenge` en texto plano"
          }
        },
        {
          "name": "Recibir mensaje (POST webhook)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 — Meta ACK', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('status === ok', () => pm.expect(json.status).to.equal('ok'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "x-hub-signature-256",
                "value": "sha256={{whatsapp_hmac_signature}}",
                "description": "HMAC-SHA256 del body crudo usando WHATSAPP_APP_SECRET. Generado por Meta en producción. Generar manualmente con backend/src/utils/hmac.util.ts para pruebas locales."
              }
            ],
            "body": {
              "mode": "raw",
